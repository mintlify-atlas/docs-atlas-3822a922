  "keyFeatures": [
    "Event and user profile tracking (pushEvent, pushChargedEvent, pushProfile)",
    "Push notifications with FCM, HMS (Huawei), and Xiaomi support",
    "In-app notifications with customizable templates and push primer support",
    "App Inbox for persistent in-app messaging",
    "Remote Variables (A/B testing and feature flags)",
    "Custom Code Templates for fully custom in-app experiences",
    "Geofencing with location-triggered campaigns",
    "Rich push notification templates (carousel, rating, timer, etc.)",
    "RenderMax SDK for improved push delivery on battery-optimized devices",
    "Multi-instance SDK support for sending data to multiple CleverTap accounts"
  ],
  "publicApiSurface": [
    "CleverTapAPI.getDefaultInstance(Context)",
    "CleverTapAPI.instanceWithConfig(Context, CleverTapInstanceConfig)",
