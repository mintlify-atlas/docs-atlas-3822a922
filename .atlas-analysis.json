    "CleverTapAPI.createNotificationChannel(Context, String, String, String, int, boolean)",
    "CleverTapAPI.registerCustomInAppTemplates(TemplatesProducer)",
    "CleverTapAPI.suspendInAppNotifications()",
    "CleverTapAPI.resumeInAppNotifications()",
    "CleverTapAPI.recordScreen(String)",
    "CleverTapAPI.setOffline(boolean)",
